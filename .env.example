# ========================================
# Foolstack Environment Configuration
# ========================================
# Copy to .env: cp .env.example .env
# Or run: make setup (auto-generates SECRET_KEY)

# ========================================
# Required
# ========================================

# Project name - used for Docker container/volume naming
PROJECT_NAME=foolstack

# Domain - serves both frontend (/) and API (/api)
# Development: localhost (Caddy uses self-signed cert)
# Production: your-domain.com (Caddy auto-provisions Let's Encrypt)
DOMAIN=localhost

# Environment mode
# development: enables debug, hot reload, verbose logging
# production: disables debug, enables security headers, optimized builds
ENVIRONMENT=development

# Django secret key - MUST be unique and secret in production
# Run 'make setup' to auto-generate, or set manually
SECRET_KEY=change-me-in-production

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
# Database password is required. 
# DB Name and User will default to PROJECT_NAME if not set.
POSTGRES_PASSWORD=foolstack

# Optional overrides:
# POSTGRES_DB=foolstack
# POSTGRES_USER=foolstack
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# ========================================
# Optional (with sensible defaults)
# ========================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Email for Let's Encrypt certificate notifications (production only)
CADDY_EMAIL=admin@example.com

# ========================================
# Email Configuration (Resend)
# ========================================
# Emails are logged to console by default in development.
# Set RESEND_API_KEY for production email delivery.
# Get your API key at: https://resend.com/api-keys

# RESEND_API_KEY=re_xxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ========================================
# Ports (all have sensible defaults)
# ========================================
# Note: In development, Vite always runs on 5173 internally.
# Only Caddy ports are typically exposed.

# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# SERVER_PORT=8000
# REDIS_PORT=6379
# CLIENT_PORT=5173
