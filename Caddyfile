# ========================================
# Foolstack Caddyfile
# ========================================
# Single domain setup with path-based routing:
# - /api/*    → Django backend
# - /admin/*  → Django admin
# - /static/* → Static files (production)
# - /*        → Vue frontend (Vite dev server or built SPA)
#
# TLS: Caddy auto-provisions based on domain
# - localhost → self-signed certificate
# - real domain → Let's Encrypt

(security_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

# Main site
{$DOMAIN:localhost} {
	import security_headers

	# API routes → Django (preserves /api prefix)
	handle /api/* {
		reverse_proxy server:{$SERVER_PORT:8000}
	}

	# Admin routes → Django (handle with and without trailing slash)
	handle /admin* {
		reverse_proxy server:{$SERVER_PORT:8000}
	}

	# Static files from Django (collectstatic output)
	handle_path /static/* {
		root * /staticfiles
		file_server
	}

	# Caddy health check
	handle /caddy-health {
		respond "OK" 200
	}

	# Frontend - everything else goes to Vue
	handle {
		@development expression {env.ENVIRONMENT} == "development"
		@production expression {env.ENVIRONMENT} != "development"

		reverse_proxy @development client:{$CLIENT_PORT:5173} {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}

		reverse_proxy @production client:{$CLIENT_PORT:80}
	}
}
