# ========================================
# Foolstack .gitignore
# ========================================

# Environment files (contains secrets)
.env
!.env.example

# ========================================
# Data Directory
# ========================================
# Keep directory structure but ignore contents
data/*
!data/.gitkeep
!data/*/
data/logs/*
!data/logs/.gitkeep
data/mediafiles/*
!data/mediafiles/.gitkeep
data/staticfiles/*
!data/staticfiles/.gitkeep
data/caddy_data/*
!data/caddy_data/.gitkeep
data/caddy_config/*
!data/caddy_config/.gitkeep

# Legacy data locations (in case they exist)
server/data/*.sqlite3
server/logs/*.log

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
env/
ENV/
venv/

# pytest
.pytest_cache/
.coverage
htmlcov/

# ========================================
# JavaScript/Node
# ========================================
node_modules/
dist/
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Bun
.bun/

# ========================================
# IDE / Editor
# ========================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# ========================================
# Claude Code
# ========================================
.claude/
